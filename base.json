{
  "baseUrl": "https://api.smsenmasse.fr/api/v1",
  "headers": {
    "Content-Type": "application/json",
    "X-API-KEY": "{{connection.apiKey}}"
  },
  "log": {
    "sanitize": ["request.headers.X-API-KEY"]
  },
  "response": {
    "error": {
      "message": "[{{statusCode}}] {{ifempty(body.message; body.error; 'Unknown error')}}"
    }
  }
}
