# Make API credentials — copy this file to .env and fill in your values.
# Get your API key at: https://www.make.com/en/api-documentation

# Your Make API key (required)
MAKE_API_KEY=

# Your Make zone, e.g. eu1.make.com or us1.make.com (required)
MAKE_ZONE=eu1.make.com

# The internal name of the app on Make (as shown in the URL)
# This is set during initial deployment and must not change afterwards
MAKE_APP_NAME=smsenmasse

# The app version to deploy to (default: 1)
MAKE_APP_VERSION=1
