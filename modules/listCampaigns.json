{
  "name": "listCampaigns",
  "label": "List Campaigns",
  "description": "Lists SMS campaigns on your SMS en Masse account with optional pagination.",
  "connection": "apiKey",
  "actionType": "search",
  "url": "{{baseUrl}}/sms",
  "method": "GET",
  "qs": {
    "page":  "{{parameters.page}}",
    "limit": "{{parameters.limit}}"
  },
  "parameters": [
    {
      "name": "page",
      "label": "Page",
      "type": "number",
      "required": false,
      "default": 1,
      "help": "Page number, starting at 1."
    },
    {
      "name": "limit",
      "label": "Results Per Page",
      "type": "number",
      "required": false,
      "default": 20,
      "help": "Number of campaigns returned (maximum 100)."
    }
  ],
  "response": {
    "iterate": "{{body}}",
    "output": [
      { "name": "id",         "label": "ID",               "type": "number" },
      { "name": "name",       "label": "Campaign Name",     "type": "text"   },
      { "name": "state",      "label": "State (code)",      "type": "number" },
      { "name": "nbTel",      "label": "Recipients Count",  "type": "number" },
      { "name": "nbSms",      "label": "SMS Count",         "type": "number" },
      { "name": "sendAt",     "label": "Send Date",         "type": "date"   },
      { "name": "finishedAt", "label": "Finished Date",     "type": "date"   },
      { "name": "sender",     "label": "Sender Name",       "type": "text"   },
      { "name": "message",    "label": "Message",           "type": "text"   },
      { "name": "identifier", "label": "Custom Identifier", "type": "text"   }
    ]
  }
}
